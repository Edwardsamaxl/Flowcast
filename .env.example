# Flowcast local env template
#
# Copy this file to `.env.local`.
# Only fill the REQUIRED values first. Keep OPTIONAL values as-is unless you know
# why you are changing them.

# =============================================================================
# REQUIRED: text generation and content analysis
# =============================================================================
DEEPSEEK_API_KEY=

# DeepSeek official OpenAI-compatible API endpoint.
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Default model for transcript analysis, voice-profile suggestions, and drafts.
# DeepSeek docs list `deepseek-v4-flash` and `deepseek-v4-pro`.
# Use flash for MVP speed/cost; switch to pro only when output quality is not enough.
DEEPSEEK_MODEL=deepseek-v4-flash

# =============================================================================
# REQUIRED for local video transcription
# =============================================================================

# Local ASR provider. Current MVP target: FunASR with your cached ModelScope model.
ASR_PROVIDER=funasr

# Detected local ffmpeg shim.
FFMPEG_PATH=C:\Users\Ed\scoop\shims\ffmpeg.exe

# Verified local ModelScope Chinese ASR model.
FUNASR_MODEL_DIR=C:\Users\Ed\.cache\modelscope\hub\models\iic\speech_paraformer-large_asr_nat-zh-cn-16k-common-vocab8404-pytorch

# =============================================================================
# REQUIRED: local file storage
# =============================================================================
APP_STORAGE_DIR=./storage
MAX_UPLOAD_MB=500

# =============================================================================
# OPTIONAL: cloud ASR fallback
# =============================================================================

# Leave empty if using local FunASR.
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# =============================================================================
# OPTIONAL: database, enabled when we add Prisma/PostgreSQL
# =============================================================================

DATABASE_URL=
