# Text generation
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# Optional. Use only when a task explicitly needs heavier reasoning.
DEEPSEEK_REASONER_MODEL=deepseek-reasoner

# Speech to text. DeepSeek does not provide ASR, so this is needed for video transcription.
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Storage
APP_STORAGE_DIR=./storage
MAX_UPLOAD_MB=500

# Database. Required when Prisma/PostgreSQL is introduced.
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/flowcast?schema=public
